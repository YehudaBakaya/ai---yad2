# ── Server ────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── JWT ───────────────────────────────────────
# החלף ב-string ארוך ורנדומלי בproduction!
JWT_SECRET=replace-with-long-random-string
SESSION_SECRET=replace-with-another-random-string

# ── MongoDB ───────────────────────────────────
# Local:  mongodb://localhost:27017/yad2ai
# Atlas:  mongodb+srv://USER:PASS@cluster.mongodb.net/yad2ai
# השאר ריק לעבוד עם in-memory (ללא DB)
MONGODB_URI=cGhPWwE9X80RmXuamongodb+srv://yehudabakaya_db_user:cGhPWwE9X80RmXua@yad2-ai.jwwjqb.mongodb.net/?appName=yad2-ai

# ── Google OAuth ──────────────────────────────
# 1. כנס ל: https://console.cloud.google.com/apis/credentials
# 2. צור "OAuth 2.0 Client ID" → Web Application
# 3. הוסף Authorized redirect URI:
#    http://localhost:3001/api/auth/google/callback
# 4. העתק Client ID ו-Secret לכאן
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

